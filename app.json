{
  "expo": {
    "name": "Asrariya",
    "slug": "asrar-mobile",
    "description": "Asrariya – Your Islamic spiritual companion. Discover daily energy alignment, Abjad numerology, Quran guidance, prayer times, compatibility insights, and AI-powered Istikhara support. Built for seekers of divine wisdom.",
    "version": "1.0.1",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "asrariya",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#0f172a",
    "primaryColor": "#6366f1",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zaibaitech.asrariya",
      "associatedDomains": [
        "applinks:asrar.app"
      ],
      "infoPlist": {
        "CFBundleDisplayName": "Asrariya",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSExceptionDomains": {
            "asrar.app": {
              "NSIncludesSubdomains": true,
              "NSTemporaryExceptionAllowsInsecureHTTPLoads": false,
              "NSExceptionRequiresForwardSecrecy": true,
              "NSExceptionMinimumTLSVersion": "TLSv1.2"
            }
          }
        },
        "UIBackgroundModes": [
          "audio",
          "fetch"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "com.zaibaitech.asrariya",
      "versionCode": 9,
      "edgeToEdgeEnabled": true,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "asrariya"
            },
            {
              "scheme": "https",
              "host": "asrar.app",
              "pathPrefix": "/auth"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.WAKE_LOCK"
      ],
      "blockedPermissions": [
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.USE_EXACT_ALARM"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "./plugins/withDisableExtraTranslationLint.js",
      "./plugins/withRemoveExactAlarmPermissions.js",
      "expo-router",
      [
        "expo-font",
        {
          "fonts": [
            "node_modules/@expo/vector-icons/build/vendor/react-native-vector-icons/Fonts/FontAwesome.ttf"
          ]
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#6366f1",
          "sounds": [
            "./assets/sounds/adhan_default.mp3",
            "./assets/sounds/adhan_mishary.mp3",
            "./assets/sounds/adhan_mecca.mp3",
            "./assets/sounds/adhan_medina.mp3",
            "./assets/sounds/adhan_fajr.mp3"
          ]
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-2859699727723534~6499298734",
          "iosAppId": "ca-app-pub-2859699727723534~3062762399",
          "userTrackingUsageDescription": "This identifier will be used to deliver personalized ads to you."
        }
      ]
    ],
    "locales": {
      "en": "./locales/en.json",
      "ar": "./locales/ar.json",
      "fr": "./locales/fr.json"
    },
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "92154153-0f9a-4685-b469-75ca8e3ce08b"
      }
    }
  }
}
